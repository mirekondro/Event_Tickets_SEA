<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" styleClass="app-background"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.event_tickets_sea.gui.CoordinatorController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <padding><Insets top="16" right="28" bottom="16" left="28"/></padding>
            <Label text="Coordinator Dashboard" styleClass="header-logo"/>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="Search my events..." styleClass="search-field" prefWidth="250"/>
            <Button mnemonicParsing="false" styleClass="btn, btn-outline" text="Log out" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0">
            <padding><Insets top="28" right="24" bottom="28" left="28"/></padding>
            <children>
                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="16">
                    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                    <Label text="My Managed Events" styleClass="section-title"/>
                    <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colEventName" prefWidth="240.0" text="Event Name" />
                            <TableColumn fx:id="colLocation" prefWidth="160.0" text="Location" />
                            <TableColumn fx:id="colStartDate" prefWidth="140.0" text="Start Date" />
                            <TableColumn fx:id="colEndDate" prefWidth="140.0" text="End Date" />
                            <TableColumn fx:id="colNotes" prefWidth="200.0" text="Notes" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </children>
        </VBox>
    </center>

    <right>
        <VBox spacing="16.0" styleClass="card" prefWidth="300.0">
            <BorderPane.margin><Insets top="28" right="28" bottom="28" left="0"/></BorderPane.margin>
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
            <children>
                <Label text="Event Setup" styleClass="section-title"/>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCreateEvent" styleClass="btn, btn-primary" text="+ New Event" />

                <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="btn, btn-secondary" text="Assign Co-Coordinator" />

                <Button fx:id="btnDeleteEvent" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleDeleteEvent" styleClass="btn, btn-danger" text="Delete Event" />

                <Separator style="-fx-padding: 12 0;" />

                <Label text="Tickets &amp; Admission" styleClass="field-label" />

                <Button maxWidth="Infinity" mnemonicParsing="false" styleClass="btn, btn-secondary" text="Manage Categories (VIP...)" />

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSpecialVouchers" styleClass="btn, btn-secondary" text="Special Vouchers (Beer/Food)" />

                <Separator style="-fx-padding: 12 0;" />

                <Label text="Sales" styleClass="field-label" />

                <Button fx:id="btnManageTickets" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleManageTickets" styleClass="btn, btn-primary, btn-large" text="Sell / Print Tickets" />

                <Button fx:id="btnViewAttendees" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleViewAttendees" styleClass="btn, btn-outline" text="View Attendees" />
            </children>
        </VBox>
    </right>

</BorderPane>