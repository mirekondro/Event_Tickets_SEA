<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="600.0" spacing="20.0" styleClass="app-background" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_sea.gui.ManageCategoriesController">
    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <VBox spacing="4.0">
        <Label styleClass="title-label" text="Manage Ticket Categories" />
        <Label styleClass="subtitle-label" text="Add, edit, or remove ticket categories for your events." />
        <Label styleClass="field-label" text="Selected Event" />
        <Label fx:id="selectedEventLabel" styleClass="subtitle-label" text="No event selected" />
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <Label styleClass="section-title" text="Add New Category" />

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Category Name *" />
            <TextField fx:id="categoryNameField" promptText="e.g., VIP, Regular, Student..." styleClass="input-field"/>
        </VBox>

        <Button maxWidth="Infinity" styleClass="btn, btn-primary" text="Add Category" onAction="#handleAddCategory"/>
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <Label styleClass="section-title" text="Existing Categories" />

        <TableView fx:id="categoriesTable" styleClass="modern-table" VBox.vgrow="ALWAYS" prefHeight="250.0">
            <columns>
                <TableColumn fx:id="colCategoryName" prefWidth="150.0" text="Category Name" />
                <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>

        <HBox spacing="12.0">
            <Button maxWidth="Infinity" styleClass="btn, btn-secondary" text="Edit" onAction="#handleEditCategory" HBox.hgrow="ALWAYS" />
            <Button maxWidth="Infinity" styleClass="btn, btn-danger" text="Delete" onAction="#handleDeleteCategory" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button styleClass="btn, btn-outline" text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>

