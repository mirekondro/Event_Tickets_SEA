<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" styleClass="app-background" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.event_tickets_sea.gui.AdminController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="16" left="28" right="28" top="16" /></padding>
            <Label styleClass="header-logo" text="System Administration" />
            <Label styleClass="badge, badge-filled" text="Admin Mode" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" styleClass="btn, btn-outline" text="Log out" onAction="#handleLogout"/>
        </HBox>
    </top>
    <center>
        <HBox spacing="20.0">
            <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>

            <VBox spacing="16" styleClass="card, admin-panel" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="User Management" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="btn, btn-danger" text="Delete User" onAction="#handleDeleteUser" style="-fx-margin: 0 8 0 0;"/>
                    <Button styleClass="btn, btn-primary" text="+ Add User" onAction="#handleAddUser" />
                </HBox>
                <TableView fx:id="usersTable" styleClass="modern-table, admin-table, users-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username" />
                        <TableColumn fx:id="colRole" prefWidth="120.0" text="Role" />
                        <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
            </VBox>

            <VBox spacing="16" styleClass="card, admin-panel" HBox.hgrow="ALWAYS">
                <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
                <Label styleClass="section-title" text="Global Events Overview" />
                <Label styleClass="subtitle-label" text="Assign coordinators or delete inappropriate events." />
                <TableView fx:id="eventsTable" styleClass="modern-table, admin-table, events-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colEventName" prefWidth="180.0" text="Event Name" />
                        <TableColumn fx:id="colCoordinator" prefWidth="150.0" text="Coordinator" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>
                <HBox spacing="12.0" styleClass="action-row">
                    <Button maxWidth="Infinity" styleClass="btn, btn-secondary" text="Assign Coordinator" onAction="#handleAssignCoordinator" HBox.hgrow="ALWAYS" />
                    <Button maxWidth="Infinity" styleClass="btn, btn-danger" text="Delete Event" onAction="#handleDeleteEvent" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>
