<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="500.0" spacing="20.0" styleClass="app-background" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_sea.gui.AddCoCoordinatorController">
    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <VBox spacing="4.0">
        <Label styleClass="title-label" text="Assign Co-Coordinator" />
        <Label styleClass="subtitle-label" text="Give another coordinator access to manage this event." />
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <Label styleClass="section-title" text="Event Information" />

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Event Name:" />
            <Label fx:id="eventNameLabel" styleClass="subtitle-label" text="[Event Name]" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        </VBox>

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Primary Coordinator:" />
            <Label fx:id="primaryCoordinatorLabel" styleClass="subtitle-label" text="[Primary Coordinator]" />
        </VBox>
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <Label styleClass="section-title" text="Current Co-Coordinators" />

        <ListView fx:id="coCoordinatorsList" prefHeight="120.0" styleClass="modern-table" />

        <HBox spacing="8.0">
            <Button fx:id="removeButton" styleClass="btn, btn-danger" text="Remove Selected" onAction="#handleRemove" disable="true" />
        </HBox>
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
        <Label styleClass="section-title" text="Add Co-Coordinator" />

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Select Coordinator *" />
            <ComboBox fx:id="coordinatorComboBox" maxWidth="Infinity" promptText="Select a coordinator to add" styleClass="input-field" />
        </VBox>

        <VBox spacing="12.0" styleClass="card" style="-fx-background-color: #EFF6FF;">
            <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
            <Label styleClass="field-label" text="ℹ️ Note:" style="-fx-text-fill: #1E40AF;" />
            <Label styleClass="subtitle-label" text="Co-coordinators can edit and manage the event but cannot delete it." wrapText="true" />
        </VBox>

        <Button fx:id="addButton" maxWidth="Infinity" styleClass="btn, btn-primary" text="Add Co-Coordinator" onAction="#handleAdd"/>
    </VBox>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button styleClass="btn, btn-outline" text="Close" onAction="#handleClose"/>
    </HBox>
</VBox>
