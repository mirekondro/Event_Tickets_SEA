<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="640.0" prefHeight="500.0" spacing="20.0" styleClass="app-background" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_sea.gui.ManageCategoriesController">
    <padding><Insets bottom="32" left="32" right="32" top="32" /></padding>

    <VBox spacing="4.0">
        <Label styleClass="title-label" text="Manage Ticket Categories" />
        <Label fx:id="selectedEventLabel" styleClass="subtitle-label" text="Event: —" />
    </VBox>

    <VBox spacing="16.0" styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

        <HBox alignment="CENTER_LEFT">
            <Label styleClass="section-title" text="Categories" />
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="btn, btn-primary" text="+ Add Category" onAction="#handleAdd" />
        </HBox>

        <TableView fx:id="categoriesTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCategoryName" prefWidth="160.0" text="Name" />
                <TableColumn fx:id="colDescription"  prefWidth="160.0" text="Description" />
                <TableColumn fx:id="colPrice"        prefWidth="120.0" text="Price" />
                <TableColumn fx:id="colQuantity"     prefWidth="100.0" text="Quantity" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox spacing="12.0">
            <Button fx:id="editButton"   styleClass="btn, btn-secondary" text="Edit Selected"   onAction="#handleEdit"   HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <Button fx:id="deleteButton" styleClass="btn, btn-danger"    text="Delete Selected" onAction="#handleDelete" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT">
        <Button styleClass="btn, btn-outline" text="Close" onAction="#handleClose" />
    </HBox>
</VBox>
