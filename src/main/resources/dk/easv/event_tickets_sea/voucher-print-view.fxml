<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<VBox alignment="CENTER" prefHeight="460.0" prefWidth="600.0" styleClass="app-background" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_sea.gui.VoucherPrintController">

    <Label text="Special Voucher Preview" styleClass="subtitle-label" style="-fx-padding: 0 0 20 0;"/>

    <VBox styleClass="ticket-container" maxWidth="350" alignment="CENTER">
        <VBox alignment="CENTER" spacing="12.0" styleClass="ticket-main"
              style="-fx-background-color: #EFF6FF; -fx-background-radius: 10px;">

            <Label text="SPECIAL VOUCHER" styleClass="badge, badge-filled"
                   style="-fx-background-color: #DBEAFE; -fx-text-fill: #1D4ED8;"/>

            <Label fx:id="descriptionLabel" text="1 FREE BEER"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1E3A8A;"
                   wrapText="true" textAlignment="CENTER"/>

            <Label fx:id="eventLabel" styleClass="subtitle-label" text="Valid for: All Events"/>

            <ImageView fx:id="qrCodeImageView" fitWidth="140" fitHeight="140" preserveRatio="true"
                       style="-fx-background-color: white;"/>

            <VBox alignment="CENTER" prefHeight="40.0" prefWidth="180.0" styleClass="barcode-placeholder">
                <Label text="|| | |||| | ||| | ||" style="-fx-font-weight: bold;"/>
            </VBox>

            <Label text="One-time use only." styleClass="field-label" style="-fx-text-fill: #EF4444;"/>
            <Label fx:id="codeLabel" styleClass="uuid-text" text="ID: -"/>
            <Label fx:id="validityLabel" styleClass="subtitle-label" text="Valid for all events"/>
        </VBox>
    </VBox>

    <Button text="Close Preview" styleClass="btn, btn-outline" onAction="#handleClose">
        <VBox.margin><Insets top="30" bottom="10"/></VBox.margin>
    </Button>
</VBox>
