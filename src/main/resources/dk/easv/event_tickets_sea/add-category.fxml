<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox prefWidth="420.0" spacing="20.0" styleClass="app-background" stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_sea.gui.AddCategoryController">
    <padding><Insets bottom="32" left="32" right="32" top="32"/></padding>

    <VBox spacing="4.0">
        <Label fx:id="formTitleLabel" styleClass="title-label" text="Add Category"/>
        <Label styleClass="subtitle-label" text="Define a ticket type with price and quantity."/>
    </VBox>

    <VBox spacing="16.0" styleClass="card">
        <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
        <Label styleClass="section-title" text="Category Details"/>

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Category Name *"/>
            <TextField fx:id="categoryNameField" promptText="e.g. VIP, Regular, Student..." styleClass="input-field"/>
        </VBox>

        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Description"/>
            <TextField fx:id="descriptionField" promptText="Short description (optional)" styleClass="input-field"/>
        </VBox>

        <HBox spacing="16.0">
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Price (DKK) *"/>
                <TextField fx:id="priceField" promptText="e.g. 99.99 or 0 for free" styleClass="input-field"/>
            </VBox>
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Quantity *"/>
                <TextField fx:id="quantityField" promptText="e.g. 100" styleClass="input-field"/>
            </VBox>
        </HBox>
    </VBox>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button styleClass="btn, btn-outline" text="Cancel" onAction="#handleCancel"/>
        <Button fx:id="saveButton" styleClass="btn, btn-primary" text="Add Category" onAction="#handleSave"/>
    </HBox>
</VBox>
